# Security-critical admin auth (required)
ADMIN_SECRET_TOKEN=replace_with_min_24_char_random_token
ADMIN_USERNAME=replace_with_admin_username
ADMIN_PASSWORD_HASH=replace_with_bcrypt_hash

# Optional only when using SHA-256 password mode instead of bcrypt hash
# ADMIN_PASSWORD=replace_with_plain_password
# ADMIN_SALT=replace_with_random_salt

# App/session secrets
SESSION_SECRET=replace_with_random_session_secret
GEMINI_API_KEY=replace_with_provider_key

# Database Connection (RDS)
# DATABASE_URL=postgresql+asyncpg://admin:password123@santis-db.xxx.eu-central-1.rds.amazonaws.com:5432/santis

# AWS S3 Global Media Strategy
# ENABLE_S3_UPLOAD=true
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=eu-central-1
# AWS_BUCKET_NAME=santis-media-global
# CDN_DOMAIN=https://cdn.santis.club
